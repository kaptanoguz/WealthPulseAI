{
  "name": "wealthpulseai",
  "version": "1.0.0",
  "description": "WealthPulse AI — Modern Finansal Varlık Yönetim Platformu. Canlı piyasa verileri, portföy yönetimi, gelir/gider takibi, ekonomi haberleri ve Monte Carlo simülasyonu.",
  "author": {
    "name": "Oğuz K.",
    "email": "kaptanoguz@users.noreply.github.com"
  },
  "license": "MIT",
  "main": "electron-main.js",
  "homepage": "https://github.com/kaptanoguz/WealthPulseAI",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaptanoguz/WealthPulseAI.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "npm run build && electron . --dev",
    "electron:build": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux deb AppImage",
    "dist:all": "npm run build && electron-builder --linux deb AppImage"
  },
  "build": {
    "appId": "com.wealthpulse.ai",
    "productName": "WealthPulse AI",
    "artifactName": "WealthPulseAI-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron-main.js",
      ".next/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.ts"
    ],
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Finance",
      "synopsis": "Modern Financial Asset Management Platform",
      "description": "WealthPulse AI - Canlı piyasa verileri, portföy yönetimi, gelir/gider takibi, ekonomi haberleri ve Monte Carlo simülasyonu içeren modern finansal varlık yönetim platformu."
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libappindicator3-1",
        "libsecret-1-0"
      ]
    }
  },
  "dependencies": {
    "@mantine/charts": "^8.3.15",
    "@mantine/core": "^8.3.15",
    "@mantine/dates": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/modals": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@tabler/icons-react": "^3.38.0",
    "dayjs": "^1.11.19",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^40.7.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "^5"
  }
}